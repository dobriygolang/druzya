{
  "name": "druz9-copilot",
  "productName": "Druz9 Copilot",
  "version": "0.1.0",
  "description": "Druz9 Copilot — stealthy AI assistant for developers (macOS desktop)",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac-dev": "electron-vite build && electron-builder --mac dir --arm64 --config.mac.identity=null --config.mac.hardenedRuntime=false --config.mac.gatekeeperAssess=false && codesign --force --deep --sign - 'dist/mac-arm64/Druz9 Copilot.app'",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.0",
    "@connectrpc/connect": "^1.4.0",
    "@connectrpc/connect-web": "^1.4.0",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@sentry/electron": "^5.11.0",
    "electron-updater": "^6.3.9",
    "keytar": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "3.23.8",
    "zustand": "^5.0.2"
  },
  "optionalDependencies": {
    "@nut-tree-fork/libnut": "^2.6.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "41.2.2",
    "electron-builder": "26.8.1",
    "electron-vite": "^3.0.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
