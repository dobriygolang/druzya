{
  "title": "druz9 — Arena",
  "uid": "druz9-arena",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["druz9", "arena"],
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Arena RPS by route",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (path) (rate(druz9_http_requests_total{path=~\"/api/v1/arena.*\"}[5m]))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Queue depth (now)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "targets": [
        {
          "expr": "sum(druz9_arena_queue_depth)",
          "legendFormat": "waiting"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Match start rate (per minute) by section/mode",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (section, mode) (rate(druz9_matches_started_total[5m])) * 60",
          "legendFormat": "{{section}}/{{mode}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Match completions by result",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (result) (rate(druz9_matches_finished_total[5m])) * 60",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Win rate (last 1h)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(druz9_matches_finished_total{result=\"win\"}[1h])) / clamp_min(sum(rate(druz9_matches_finished_total[1h])), 1)",
          "legendFormat": "win"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Matchmaking wait p50/p99 (s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 16, "w": 18, "h": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(druz9_queue_wait_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(druz9_queue_wait_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 180 }
            ]
          }
        }
      }
    }
  ]
}
