{
  "title": "druz9 — Business",
  "uid": "druz9-business",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["druz9", "business"],
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "ch",
        "type": "datasource",
        "query": "grafana-clickhouse-datasource",
        "current": { "text": "ClickHouse", "value": "ClickHouse" }
      },
      {
        "name": "prom",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "DAU (last 24h)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${ch}" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "targets": [
        { "rawSql": "SELECT uniqExact(user_id) AS dau FROM events WHERE ts >= now() - INTERVAL 1 DAY" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "MAU (last 30d)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${ch}" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "targets": [
        { "rawSql": "SELECT uniqExact(user_id) AS mau FROM events WHERE ts >= now() - INTERVAL 30 DAY" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Free → Premium conversion (30d)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${ch}" },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 5 },
      "targets": [
        { "rawSql": "SELECT countIf(name='premium_upgrade') / nullIf(countIf(name='signup'), 0) AS conv FROM events WHERE ts >= now() - INTERVAL 30 DAY" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 0.05 }
          ]}
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Retention D7",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${ch}" },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 5 },
      "targets": [
        { "rawSql": "WITH cohort AS (SELECT user_id, min(toDate(ts)) AS d0 FROM events GROUP BY user_id), returned AS (SELECT DISTINCT e.user_id FROM events e JOIN cohort c ON c.user_id = e.user_id WHERE toDate(e.ts) = c.d0 + INTERVAL 7 DAY) SELECT count() / (SELECT count() FROM cohort WHERE d0 <= today() - 7) AS d7 FROM returned" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 0.25 }
          ]}
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Matches per day, by section",
      "datasource": { "type": "prometheus", "uid": "${prom}" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (section) (increase(druz9_matches_started_total[1d]))", "legendFormat": "{{section}}" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Avg matchmaking wait (s) per section",
      "datasource": { "type": "prometheus", "uid": "${prom}" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (section) (rate(druz9_queue_wait_seconds_sum[10m])) / sum by (section) (rate(druz9_queue_wait_seconds_count[10m]))", "legendFormat": "{{section}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 180 }
          ]}
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Mock dropout rate",
      "datasource": { "type": "prometheus", "uid": "${prom}" },
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(druz9_mock_sessions_total{status=\"abandoned\"}[1h])) / sum(rate(druz9_mock_sessions_total[1h]))", "legendFormat": "dropout" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0.4 }
          ]}
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Active guilds per week",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${ch}" },
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "rawSql": "SELECT toStartOfWeek(ts) AS t, uniqExact(JSONExtractString(props, 'guild_id')) AS active FROM events WHERE name IN ('match_finished','guild_war_contribution') AND ts >= now() - INTERVAL 90 DAY GROUP BY t ORDER BY t" }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Avg score per section (mocks, 7d)",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${ch}" },
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 8 },
      "targets": [
        { "rawSql": "SELECT section, avg(score) AS avg_score, count() AS n FROM events WHERE name='mock_completed' AND ts >= now() - INTERVAL 7 DAY GROUP BY section ORDER BY n DESC" }
      ]
    }
  ]
}
