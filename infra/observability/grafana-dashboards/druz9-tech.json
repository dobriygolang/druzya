{
  "title": "druz9 — Tech (HTTP / WS / Infra)",
  "uid": "druz9-tech",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["druz9", "tech"],
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (path) (rate(druz9_http_requests_total[5m]))", "legendFormat": "{{path}}" }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP latency p50 / p95 / p99",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(druz9_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(druz9_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(druz9_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error rate (5m)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "targets": [
        { "expr": "sum(rate(druz9_http_errors_total[5m])) / sum(rate(druz9_http_requests_total[5m]))", "legendFormat": "error rate" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "WS active connections per hub",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 6, "y": 8, "w": 9, "h": 6 },
      "targets": [
        { "expr": "druz9_ws_active_connections", "legendFormat": "{{hub}}" }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Judge0 backlog",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 15, "y": 8, "w": 9, "h": 6 },
      "targets": [
        { "expr": "druz9_judge0_pending_submissions", "legendFormat": "pending" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Postgres connection pool",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "targets": [
        { "expr": "pg_stat_activity_count", "legendFormat": "{{state}}" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Redis memory used",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "targets": [
        { "expr": "redis_memory_used_bytes", "legendFormat": "used" },
        { "expr": "redis_memory_max_bytes", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
