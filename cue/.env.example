# Cue desktop — runtime configuration.
# Copy to .env (gitignored) and tune for local dev.

# Backend monolith. Default in dev = http://localhost:8080 (matches `make start`).
# Production builds default to https://druz9.online.
DRUZ9_API_BASE_URL=http://localhost:8080

# Update feed (electron-updater). Empty disables auto-update — fine for local dev.
DRUZ9_UPDATE_FEED_URL=

# Sentry DSN. Empty disables crash reporting.
DRUZ9_SENTRY_DSN=

# Default UI locale at first launch (user can override via Settings).
DRUZ9_DEFAULT_LOCALE=ru

# Audio source for voice transcription: 'mic' or 'system'.
DRUZ9_VOICE_SOURCE=mic
