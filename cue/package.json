{
  "name": "druz9-copilot",
  "productName": "Cue",
  "version": "0.1.0",
  "description": "Cue — stealthy AI assistant for developers (macOS desktop)",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:mac-dev": "electron-vite build && electron-builder --mac dir --arm64 --config.mac.identity=null --config.mac.hardenedRuntime=false --config.mac.gatekeeperAssess=false && codesign --force --deep --sign - 'dist/mac-arm64/Cue.app'",
    "build:masquerade:notes": "electron-vite build && electron-builder --mac --config electron-builder.notes.yml --publish never",
    "build:masquerade:telegram": "electron-vite build && electron-builder --mac --config electron-builder.telegram.yml --publish never",
    "build:masquerade:slack": "electron-vite build && electron-builder --mac --config electron-builder.slack.yml --publish never",
    "build:masquerade:xcode": "electron-vite build && electron-builder --mac --config electron-builder.xcode.yml --publish never",
    "build:masquerade:all": "bash scripts/build-masquerade.sh",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:stealth": "bash scripts/smoke-stealth.sh",
    "build:native-mac": "./native/audio-mac/build.sh && ./native/CursorHelper/build.sh",
    "build:stealth-verifier": "./native/stealth-verifier/build.sh"
  },
  "dependencies": {
    "@connectrpc/connect": "^1.4.0",
    "@connectrpc/connect-web": "^1.4.0",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@sentry/electron": "^5.11.0",
    "electron-updater": "^6.3.9",
    "keytar": "^7.9.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "3.23.8",
    "zustand": "^5.0.2"
  },
  "optionalDependencies": {
    "@nut-tree-fork/libnut": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "41.2.2",
    "electron-builder": "26.8.1",
    "electron-vite": "^3.0.0",
    "eslint": "^9.39.4",
    "globals": "^15.15.0",
    "happy-dom": "^15.11.7",
    "js-yaml": "^4.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.9"
  }
}
