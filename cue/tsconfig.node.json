{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@shared/*": ["./src/shared/*"],
      "@main/*": ["./src/main/*"],
      "@generated/*": ["../frontend/src/api/generated/*"],
      "@bufbuild/protobuf": ["./node_modules/@bufbuild/protobuf"],
      "@bufbuild/protobuf/*": ["./node_modules/@bufbuild/protobuf/*"],
      "@connectrpc/connect": ["./node_modules/@connectrpc/connect"],
      "@connectrpc/connect/*": ["./node_modules/@connectrpc/connect/*"]
    },
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "src/main/**/*",
    "src/shared/**/*",
    "src/test/**/*",
    "electron.vite.config.ts",
    "vitest.config.ts"
  ],
  "exclude": ["src/renderer/**/*", "out", "dist", "node_modules"]
}
