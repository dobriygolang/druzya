{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false,
    // baseUrl deprecated в TS 7. Под bundler moduleResolution paths работают без него
    // (resolve относительно tsconfig). Если когда-то нужен будет fallback —
    // верни baseUrl + добавь "ignoreDeprecations": "6.0".
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
