# druz9 production environment. Copy to .env.prod on the server, fill with
# real secrets, chmod 600, keep out of git. Referenced by
# infra/docker-compose.prod.yml via `env_file`.

# ── Meta
APP_ENV=production
PRIMARY_DOMAIN=druz9.online
SECONDARY_DOMAIN=druz9.ru
PUBLIC_BASE_URL=https://druz9.online

# ── API image (CI writes this; deploy.sh overrides).
API_IMAGE=ghcr.io/dobriygolang/druz9-api:latest

# ── Postgres
POSTGRES_USER=druz9
POSTGRES_PASSWORD=change-me-long-random-string
POSTGRES_DB=druz9

# ── Redis
REDIS_PASSWORD=change-me-long-random-string

# ── MinIO (S3)
# ROOT_USER/PASSWORD configure the MinIO server itself.
# ACCESS_KEY/SECRET_KEY are what the api uses to authenticate against it —
# typically same values as ROOT_USER/PASSWORD for single-tenant deploys.
MINIO_ROOT_USER=druz9minio
MINIO_ROOT_PASSWORD=change-me-long-random-string
MINIO_ACCESS_KEY=druz9minio
MINIO_SECRET_KEY=change-me-long-random-string

# ── ClickHouse
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me

# ── Auth
JWT_SECRET=change-me-64-byte-hex-string
JWT_ACCESS_TTL=86400
JWT_REFRESH_TTL=2592000
ENCRYPTION_KEY=change-me-32-byte-string-for-aes-gcm

# ── Yandex OAuth (BotFather-like setup at oauth.yandex.ru)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# ── Telegram Bot (@BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-long-random-string

# ── LLM (openrouter.ai — one key, all providers)
OPENROUTER_API_KEY=
LLM_DEFAULT_FREE=openai/gpt-4o-mini
LLM_DEFAULT_PAID=openai/gpt-4o

# ── Editor invite signing (bible §3.1)
EDITOR_INVITE_SECRET=change-me-32-byte-string

# ── WS
WS_ALLOWED_ORIGINS=https://druz9.online,https://www.druz9.online

# ── SMTP (optional, fallback notification channel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Observability через Grafana Cloud (free tier).
# Где взять:
#   1. https://grafana.com → My Account → Stack
#   2. Prometheus → "Send Metrics" → копируй URL и Username
#   3. Loki → "Send Logs" → URL + Username
#   4. Tempo → "Send Traces" → OTLP HTTP endpoint
#   5. Access Policies → New token со scope: metrics:write,logs:write,traces:write
#      → этот же токен используется во всех трёх сервисах (это API_KEY).
GRAFANA_CLOUD_API_KEY=
# Prometheus remote_write
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-eu-west-2.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USER=
# Loki push
GRAFANA_CLOUD_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GRAFANA_CLOUD_LOKI_USER=
# Tempo OTLP/HTTP. ENDPOINT — без /v1/traces (SDK добавит сам).
# HEADERS — Basic-токен в формате: Authorization=Basic <base64(user:token)>
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-eu-west-2.grafana.net/otlp
GRAFANA_CLOUD_OTLP_HEADERS=Authorization=Basic CHANGE_ME_BASE64

# ── Let's Encrypt (used once by bootstrap.sh; not read by containers)
LETSENCRYPT_EMAIL=ops@druz9.online
