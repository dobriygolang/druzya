# Copy to .env — never commit real secrets.

APP_ENV=local
HTTP_ADDR=:8080

POSTGRES_DSN=host=postgres port=5432 user=druz9 password=druz9 dbname=druz9 sslmode=disable
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=druz9minio
MINIO_SECRET_KEY=druz9minio-dev
MINIO_USE_SSL=false
# Bucket for the podcasts CMS uploader (services/podcast). Operator must
# create the bucket once via `mc mb minio/podcasts`. Empty → defaults to
# "podcasts".
MINIO_BUCKET_PODCASTS=podcasts

CLICKHOUSE_ADDR=clickhouse:9000
CLICKHOUSE_DB=druz9
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

JUDGE0_URL=http://judge0-server:2358

JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=86400
JWT_REFRESH_TTL=2592000

YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-random-string
PUBLIC_BASE_URL=http://localhost:8080

WS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
ENCRYPTION_KEY=change-me-32-byte-key-for-aes-gcm

OPENROUTER_API_KEY=
LLM_DEFAULT_FREE=openai/gpt-4o-mini
LLM_DEFAULT_PAID=openai/gpt-4o

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
