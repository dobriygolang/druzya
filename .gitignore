# OS
.DS_Store
.claude
.cache

# Env
.env
.env.*
!.env.example
!.env.prod.example
# Frontend Vite-build envs нужно трекать — туда попадают VITE_* которые
# встраиваются в bundle через `vite build`. Не содержат секретов: только
# OAuth client_id (публичный, и так в URL Yandex authorize) и bot_name.
!frontend/.env.production
!frontend/.env.development

# Go
/bin/
*.out
vendor/
backend/cmd/monolith/monolith
# Когда вырежем сервисы из монолита — добавляй явные строки сюда:
# backend/cmd/<svc>/<svc>  — конкретный бинарник.
# Старое правило `backend/cmd/*/[a-z]*` было слишком широким — оно молча
# игнорировало файлы внутри backend/cmd/monolith/services/ (services
# начинается с lowercase, а *.go-override не работал, потому что gitignore
# не пере-инклюдит файлы из уже игнорируемых папок).
# Coverage / профайлы
*.cov
*.prof
*.test

# Generated code is COMMITTED (bible §16: treat as reviewable artefacts).
# If you want to opt OUT for a specific module, add it here explicitly.

# Node
node_modules/
dist/
coverage/
*.log
frontend/.vite

# IDE
.idea/
.vscode/

# Docker
*.pid

# MSW
frontend/public/mockServiceWorker.js

# Local test dumps
/tmp/
/test-output/
/private/
